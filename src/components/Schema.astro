---
// src/components/Schema.astro
const websiteUrl = 'https://yobix.in';
const contactPhone = '+918344647780';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Yobix',
  url: websiteUrl,
  logo: `${websiteUrl}/logo.webp`,
  telephone: contactPhone,
  email: 'info@yobix.in',
  sameAs: [
    'https://www.instagram.com/yobix.in/'
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: contactPhone,
    contactType: 'sales',
    areaServed: 'IN',
    availableLanguage: ['en']
  }
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Yobix Business Intelligence Suite',
  operatingSystem: 'All',
  applicationCategory: 'BusinessApplication',
  offers: {
    '@type': 'Offer',
    price: '0.00',
    priceCurrency: 'USD',
    description: 'Free sandbox testing and platform walkthrough demo.'
  },
  description: 'Sub-second real-time business intelligence and data visualization platform connected to enterprise database clusters.',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '128'
  }
};
---

{/* Injecting schemas into the <head> */}
<script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />
<script type="application/ld+json" is:inline set:html={JSON.stringify(appSchema)} />