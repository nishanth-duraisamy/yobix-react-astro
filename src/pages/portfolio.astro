---
import MainLayout from '../layouts/MainLayout.astro';
import PortfolioContent from '../components/PortfolioContent';

const title = "Case Studies & Analytics Work | Yobix";
const description = "Explore the enterprise data modeling, real-time analytics sync, and white-labeled embedded dashboard case studies from Yobix.";
const ogTitle = "Case Studies & Analytics Work | Yobix";
const ogDescription = "Explore the enterprise analytics and embedded dashboard case studies from Yobix.";
const ogUrl = "https://yobix.in/portfolio";
---

<MainLayout title={title} description={description} ogTitle={ogTitle} ogDescription={ogDescription} ogUrl={ogUrl}>
    <PortfolioContent client:load />
</MainLayout>
