---
// src/pages/index.astro
import MainLayout from '../layouts/MainLayout.astro';
import HeroSection from '../components/HeroSection';
import HomeContent from '../components/HomeContent';

// Define the specific SEO for the homepage
const title = "Yobix - Sub-Second Real-Time Business Intelligence Platform";
const description = "Connect Yobix to your database clusters and cloud warehouses to render interactive dashboards instantly. Experience sub-second query speeds without manual indexes.";
const ogTitle = "Yobix - Sub-Second Real-Time Business Intelligence Platform";
const ogDescription = "Connect Yobix to your database clusters and cloud warehouses to render interactive dashboards instantly.";
const ogUrl = "https://yobix.in/";
const ogImage = "https://yobix.in/logo.webp";
const twitterCard = "summary_large_image";
const twitterTitle = "Yobix - Sub-Second Real-Time Business Intelligence Platform";
const twitterDescription = "Connect Yobix to your database clusters and cloud warehouses to render interactive dashboards instantly.";
const twitterImage = "https://yobix.in/logo.webp";
---

<MainLayout
    title={title}
    description={description}
    fullWidth={true}
    ogTitle={ogTitle}
    ogDescription={ogDescription}
    ogUrl={ogUrl}
    ogImage={ogImage}
    twitterCard={twitterCard}
    twitterTitle={twitterTitle}
    twitterDescription={twitterDescription}
    twitterImage={twitterImage}
>
  <HeroSection client:load />

  <HomeContent />
</MainLayout>