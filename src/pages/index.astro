---
// src/pages/index.astro
import MainLayout from '../layouts/MainLayout.astro';
import HeroSection from '../components/HeroSection';
import HomeContent from '../components/HomeContent';

const title = "Yobix - Real-Time Business Intelligence & Operational Growth Platform";
const description = "Implement the Yobix Framework to diagnose your business bottleneck and track real-time operational metrics. Experience accelerated revenue and cost control.";
const ogTitle = "Yobix - Real-Time Business Intelligence & Operational Growth Platform";
const ogDescription = "Implement the Yobix Framework to diagnose your business bottleneck and track real-time operational metrics.";
const ogUrl = "https://yobix.in/";
const ogImage = "https://yobix.in/logo.webp";
const twitterCard = "summary_large_image";
const twitterTitle = "Yobix - Real-Time Business Intelligence & Operational Growth Platform";
const twitterDescription = "Implement the Yobix Framework to diagnose your business bottleneck and track real-time operational metrics.";
const twitterImage = "https://yobix.in/logo.webp";
---

<MainLayout
    title={title}
    description={description}
    fullWidth={true}
    ogTitle={ogTitle}
    ogDescription={ogDescription}
    ogUrl={ogUrl}
    ogImage={ogImage}
    twitterCard={twitterCard}
    twitterTitle={twitterTitle}
    twitterDescription={twitterDescription}
    twitterImage={twitterImage}
>
  <HeroSection client:load />

  <HomeContent />
</MainLayout>