---
import MainLayout from '../layouts/MainLayout.astro';
import AboutUsComponent from '../components/AboutUs';

const title = "About Yobix - Our Story & Mission";
const description = "Learn about Yobix's mission to empower enterprises with sub-second real-time database query visualizations, custom analytics, and cloud architectures.";
---

<MainLayout title={title} description={description} fullWidth={true} ogTitle="About Yobix" ogDescription="Learn about Yobix's mission to empower enterprises with sub-second real-time database query visualizations." ogUrl="https://yobix.in/about">
    <AboutUsComponent />
</MainLayout>