---
import MainLayout from '../layouts/MainLayout.astro';
import AboutUsComponent from '../components/AboutUs';

const title = "About Yobix - Our Story & Mission";
const description = "Learn about Yobix's mission to empower businesses with real-time growth diagnostics, performance metrics, and operational optimizations.";
