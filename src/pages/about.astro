<MainLayout title={title} description={description} fullWidth={true} ogTitle="About Yobix" ogDescription="Learn about Yobix's mission to empower businesses with real-time operational growth diagnostics." ogUrl="https://yobix.in/about">
    <AboutUsComponent />
</MainLayout>