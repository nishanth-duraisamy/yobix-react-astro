---
// src/pages/appointments.astro
import MainLayout from '../layouts/MainLayout.astro';
import BookingIsland from '../components/BookingIsland';

const title = "Schedule a Yobix Demo & Product Tour";
const description = "Schedule your next product tour or architecture demo with Yobix. Choose your BI solutions, scale size, and connecting region.";
const ogTitle = "Schedule a Yobix Demo & Product Tour";
const ogUrl = "https://yobix.in/appointments";
---

<MainLayout title={title} description={description} fullWidth={true} ogTitle={ogTitle} ogUrl={ogUrl}>
    <div class="bg-background text-text-main py-12 px-4 sm:px-6 lg:px-8">
        <BookingIsland client:only="react" />
    </div>
</MainLayout>