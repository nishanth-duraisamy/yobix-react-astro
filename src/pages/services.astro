---
import MainLayout from '../layouts/MainLayout.astro';
import ServicesSection from '../components/ServicesSection';

const title = "Features & Services | Yobix BI";
const description = "Explore the range of business intelligence features offered by Yobix, including real-time analytics, embedded dashboard SDKs, migration tools, and custom database schema modeling.";
const ogTitle = "Features & Services | Yobix BI";
const ogDescription = "Explore the range of business intelligence features offered by Yobix.";
const ogUrl = "https://yobix.in/services";
---

<MainLayout title={title} description={description} fullWidth={true} ogTitle={ogTitle} ogDescription={ogDescription} ogUrl={ogUrl}>
    <ServicesSection client:load />
</MainLayout>