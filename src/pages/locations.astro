---
import MainLayout from '../layouts/MainLayout.astro';
import LocationsComponent from '../components/LocationsComponent';

const title = "Our Offices and Presence | Yobix BI";
const description = "Find Yobix head offices and development hubs. Get directions, contact information, and tour booking links.";
const ogTitle = "Our Offices and Presence | Yobix BI";
const ogDescription = "Find Yobix head offices and development hubs.";
const ogUrl = "https://yobix.in/locations";
---

<MainLayout title={title} description={description} ogTitle={ogTitle} ogDescription={ogDescription} ogUrl={ogUrl}>
    <LocationsComponent />
</MainLayout>