---
// src/pages/contact.astro
import MainLayout from '../layouts/MainLayout.astro';
import Contact from '../components/Contact';

const title = "Contact Yobix - Business Intelligence Platform";
const description = "Get in touch with Yobix for system demonstrations, sales inquiries, custom data architecture consultations, and enterprise support.";
const ogTitle = "Contact Yobix - Business Intelligence Platform";
const ogDescription = "Get in touch with Yobix for system demonstrations, sales inquiries, and support.";
const ogUrl = "https://yobix.in/contact";
---

<MainLayout title={title} description={description} fullWidth={true} ogTitle={ogTitle} ogDescription={ogDescription} ogUrl={ogUrl}>
    <Contact />

    <div class='bg-background text-text-main py-12'>
        <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
            <h2 class='text-3xl font-display text-primary text-center mb-6 font-bold'>
                Connect with the Yobix Team
            </h2>
            <p class='text-lg text-text-muted text-center leading-relaxed max-w-4xl mx-auto'>
                At Yobix, we're dedicated to helping you optimize your business growth strategies, build scalable operational metrics tracking dashboards, and control company overhead costs. Whether you are looking for custom diagnostics integration or have strategic questions, our team is ready to assist.
                <br />
                <br />
                Reach out to us via email, phone, or connect with our engineering team on social platforms. We look forward to partnering with you on your analytics journey with <span class='text-primary font-semibold'>Yobix</span>.
            </p>
        </div>
    </div>
</MainLayout>